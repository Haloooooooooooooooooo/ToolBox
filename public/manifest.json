{
  "manifest_version": 3,
  "name": "PinBase",
  "description": "快速收藏和查找常用网站的浏览器插件。",
  "version": "0.1.0",
  "action": {
    "default_title": "PinBase",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "options_page": "options.html",
  "permissions": ["storage", "tabs", "activeTab"],
  "commands": {
    "add-current-site": {
      "suggested_key": {
        "default": "Alt+Shift+S"
      },
      "description": "快速收录当前网站"
    }
  }
}
