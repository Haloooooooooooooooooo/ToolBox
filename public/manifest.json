{
  "manifest_version": 3,
  "name": "PinBase",
  "description": "快速收藏、分类整理并查找常用网站的浏览器扩展。",
  "version": "0.1.0",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "PinBase",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "options_page": "options.html",
  "permissions": ["storage", "tabs", "scripting", "permissions"],
  "host_permissions": ["<all_urls>"],
  "commands": {
    "add-current-site": {
      "suggested_key": {
        "default": "Alt+Shift+K"
      },
      "description": "快速收录当前网站"
    }
  }
}
